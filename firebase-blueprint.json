{
  "entities": {
    "customer": {
      "title": "Customer",
      "description": "Customer entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "companyName": { "type": "string" }
      }
    },
    "product": {
      "title": "Product",
      "description": "Product entity",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" }
      }
    },
    "quotation": {
      "title": "Quotation",
      "description": "Quotation entity",
      "type": "object",
      "properties": {
        "quoteNo": { "type": "string" },
        "customerId": { "type": "string" },
        "deliveryCharges": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/customers/{customerId}": {
      "schema": "#/entities/customer",
      "description": "Customers collection"
    },
    "/products/{productId}": {
      "schema": "#/entities/product",
      "description": "Products collection"
    },
    "/quotations/{quotationId}": {
      "schema": "#/entities/quotation",
      "description": "Quotations collection"
    }
  }
}
