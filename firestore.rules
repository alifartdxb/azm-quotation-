rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.get('email', '') == 'alifartdxb@gmail.com') ||
        (request.auth.token.get('email', '') == 'admin@azmgroup.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN')
      );
    }
    
    function isManager() {
      return isAuthenticated() && (
        (request.auth.token.get('email', '') == 'alifartdxb@gmail.com') ||
        (request.auth.token.get('email', '') == 'admin@azmgroup.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SUPER_ADMIN' || 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'SALES_MANAGER'))
      );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // Allow user to write to their own doc initially, or superadmin
      allow write: if isSuperAdmin() || request.auth.uid == userId;
    }
    
    match /products/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }
    
    match /quotations/{document=**} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isManager();
    }
    
    match /settings/{document=**} {
      allow read: if isAuthenticated();
      // Temporary check just to be 100% sure the superadmin rule isn't tossing generic errors 
      // if token.email is missing for some reason
      allow write: if isSuperAdmin();
    }
    
    match /counters/{document=**} {
      allow read, write: if isAuthenticated();
    }
    
    match /audit_logs/{document=**} {
      allow read: if isSuperAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false; // Immutable audit logs
    }
    
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
